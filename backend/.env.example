# ── Postulator Backend — .env.example ─────────────────────────────────────────
# Copier ce fichier en .env et adapter les valeurs

APP_NAME=Postulator
APP_VERSION=0.1.0
DEBUG=true

# Base de données
DATABASE_URL=sqlite+aiosqlite:///./postulator.db

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
# Modèle recommandé : qwen2.5:14b (meilleure qualité) ou phi3.5:3.8b (plus rapide)
OLLAMA_MODEL=phi3.5:3.8b

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# CORS (séparer plusieurs origines par virgule)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Scrapers
SCRAPER_DEFAULT_RESULTS=50
SCRAPER_MAX_RESULTS=200
SCRAPER_DELAY_MIN=3
SCRAPER_DELAY_MAX=10

# Proxies statiques optionnels (format HTTP, séparés par virgule)
# Pour les proxies résidentiels saisis en UI, utiliser POST /api/scrapers/run-with-proxies
PROXY_LIST=

# Alertes email (optionnel — laisser vide si non utilisé)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
# Seuil de score pour déclencher une alerte email (0-100)
ALERT_SCORE_THRESHOLD=80
