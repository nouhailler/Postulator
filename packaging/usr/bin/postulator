#!/bin/bash
# ─────────────────────────────────────────────────────────────
#  Postulator — script de démarrage
#  Lance automatiquement Redis, l'API FastAPI, le worker Celery
#  et le frontend React, puis ouvre le navigateur.
# ─────────────────────────────────────────────────────────────

INSTALL_DIR="/opt/postulator"
LOG_DIR="$HOME/.postulator/logs"
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

mkdir -p "$LOG_DIR"

# ── Vérification des permissions au premier lancement ────────
if [ ! -w "${INSTALL_DIR}/frontend" ]; then
    echo -e "${RED}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${RED}║  ERREUR : Permissions insuffisantes sur ${INSTALL_DIR}  ║${NC}"
    echo -e "${RED}╠══════════════════════════════════════════════════════════╣${NC}"
    echo -e "${RED}║  Corrigez avec :                                         ║${NC}"
    echo -e "${RED}║    sudo chown -R \$USER:\$USER ${INSTALL_DIR}             ║${NC}"
    echo -e "${RED}║  puis relancez : postulator                              ║${NC}"
    echo -e "${RED}╚══════════════════════════════════════════════════════════╝${NC}"
    exit 1
fi

echo ""
echo -e "${BLUE}╔══════════════════════════════════════╗${NC}"
echo -e "${BLUE}║         Démarrage Postulator         ║${NC}"
echo -e "${BLUE}╚══════════════════════════════════════╝${NC}"
echo ""

# ── Nettoyage des anciens processus ────────────────────────
# Évite que Vite démarre sur 5174 si 5173 est déjà pris par
# une ancienne instance (problème lors des mises à jour .deb)
echo -e "${YELLOW}[0/4] Nettoyage des anciens processus...${NC}"
pkill -f "uvicorn app.main:app" 2>/dev/null && sleep 1
pkill -f "celery.*postulator"   2>/dev/null
pkill -f "vite"                 2>/dev/null
# Libérer les ports 8000 et 5173 si encore occupés
for PORT in 8000 5173; do
    PID=$(lsof -ti tcp:$PORT 2>/dev/null)
    if [ -n "$PID" ]; then
        kill "$PID" 2>/dev/null
        sleep 0.5
    fi
done
echo -e "      ${GREEN}✓ Ports 8000 et 5173 libérés${NC}"

# ── Redis ──────────────────────────────────────────────────
echo -e "${YELLOW}[1/4] Redis...${NC}"
if ! redis-cli ping &>/dev/null; then
    sudo systemctl start redis-server 2>/dev/null || \
    redis-server --daemonize yes --logfile "$LOG_DIR/redis.log"
fi
redis-cli ping &>/dev/null && echo -e "      ${GREEN}✓ Redis OK${NC}" || \
    { echo -e "      ${RED}✗ Redis non disponible${NC}"; exit 1; }

# ── API FastAPI ────────────────────────────────────────────
echo -e "${YELLOW}[2/4] API FastAPI...${NC}"
cd "$INSTALL_DIR/backend"
source .venv/bin/activate
nohup uvicorn app.main:app --port 8000 > "$LOG_DIR/api.log" 2>&1 &
API_PID=$!
# Attendre que l'API réponde (jusqu'à 15s)
for i in $(seq 1 15); do
    sleep 1
    if curl -s http://localhost:8000/api/dashboard/overview &>/dev/null; then
        echo -e "      ${GREEN}✓ API OK (pid $API_PID)${NC}"
        break
    fi
    if [ "$i" -eq 15 ]; then
        echo -e "      ${YELLOW}⚠ API en démarrage... (pid $API_PID) — vérifiez $LOG_DIR/api.log${NC}"
    fi
done

# ── Worker Celery ──────────────────────────────────────────
echo -e "${YELLOW}[3/4] Worker Celery...${NC}"
nohup celery -A app.workers.celery_app.celery_app worker \
    --loglevel=warning > "$LOG_DIR/celery.log" 2>&1 &
CELERY_PID=$!
sleep 1
echo -e "      ${GREEN}✓ Worker OK (pid $CELERY_PID)${NC}"
deactivate

# ── Frontend React ─────────────────────────────────────────
echo -e "${YELLOW}[4/4] Frontend...${NC}"
cd "$INSTALL_DIR/frontend"
nohup npm run dev > "$LOG_DIR/frontend.log" 2>&1 &
FRONTEND_PID=$!

# Vérification réelle : attendre que le port 5173 réponde (jusqu'à 20s)
FRONTEND_PORT=5173
FRONTEND_OK=false
for i in $(seq 1 20); do
    sleep 1
    # Détecter le port réel depuis les logs (5173 ou 5174 si conflit)
    DETECTED_PORT=$(grep -oP 'Local:\s+http://localhost:\K\d+' "$LOG_DIR/frontend.log" 2>/dev/null | head -1)
    if [ -n "$DETECTED_PORT" ]; then
        FRONTEND_PORT=$DETECTED_PORT
        FRONTEND_OK=true
        break
    fi
    # Détecter l'erreur de permissions dès qu'elle apparaît dans les logs
    if grep -q "EACCES: permission denied" "$LOG_DIR/frontend.log" 2>/dev/null; then
        echo -e "      ${RED}✗ Erreur de permissions sur le frontend${NC}"
        echo -e "      ${RED}  Corrigez : sudo chown -R \$USER:\$USER ${INSTALL_DIR}${NC}"
        kill "$API_PID" "$CELERY_PID" "$FRONTEND_PID" 2>/dev/null
        exit 1
    fi
done

if $FRONTEND_OK; then
    echo -e "      ${GREEN}✓ Frontend OK (pid $FRONTEND_PID) — http://localhost:${FRONTEND_PORT}${NC}"
else
    echo -e "      ${YELLOW}⚠ Frontend lent à démarrer (pid $FRONTEND_PID)${NC}"
    echo -e "      ${YELLOW}  Logs : tail -f $LOG_DIR/frontend.log${NC}"
fi

# ── Résumé ─────────────────────────────────────────────────
echo ""
echo -e "${GREEN}╔══════════════════════════════════════╗${NC}"
echo -e "${GREEN}║   Postulator prêt !                  ║${NC}"
echo -e "${GREEN}║   → http://localhost:${FRONTEND_PORT}            ║${NC}"
echo -e "${GREEN}║                                      ║${NC}"
echo -e "${GREEN}║   Logs : ~/.postulator/logs/         ║${NC}"
echo -e "${GREEN}║   Arrêt : Ctrl+C                     ║${NC}"
echo -e "${GREEN}╚══════════════════════════════════════╝${NC}"
echo ""

# Ouvrir le navigateur sur le bon port
sleep 1
if command -v xdg-open &>/dev/null; then
    xdg-open "http://localhost:${FRONTEND_PORT}" &
elif command -v gnome-open &>/dev/null; then
    gnome-open "http://localhost:${FRONTEND_PORT}" &
fi

# Garder le script actif — arrêt propre sur Ctrl+C
trap "echo ''; echo 'Arrêt de Postulator...'; kill $API_PID $CELERY_PID $FRONTEND_PID 2>/dev/null; exit 0" INT TERM
wait
