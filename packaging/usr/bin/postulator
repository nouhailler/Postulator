#!/bin/bash
# ─────────────────────────────────────────────────────────────
#  Postulator — script de démarrage
#  Lance automatiquement Redis, l'API FastAPI, le worker Celery
#  et le frontend React, puis ouvre le navigateur.
# ─────────────────────────────────────────────────────────────

INSTALL_DIR="/opt/postulator"
LOG_DIR="$HOME/.postulator/logs"
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

mkdir -p "$LOG_DIR"

echo ""
echo -e "${BLUE}╔══════════════════════════════════════╗${NC}"
echo -e "${BLUE}║         Démarrage Postulator         ║${NC}"
echo -e "${BLUE}╚══════════════════════════════════════╝${NC}"
echo ""

# ── Redis ──────────────────────────────────────────────────
echo -e "${YELLOW}[1/4] Redis...${NC}"
if ! redis-cli ping &>/dev/null; then
    sudo systemctl start redis-server 2>/dev/null || \
    redis-server --daemonize yes --logfile "$LOG_DIR/redis.log"
fi
redis-cli ping &>/dev/null && echo -e "      ${GREEN}✓ Redis OK${NC}" || \
    { echo -e "      ${RED}✗ Redis non disponible${NC}"; exit 1; }

# ── API FastAPI ────────────────────────────────────────────
echo -e "${YELLOW}[2/4] API FastAPI...${NC}"
cd "$INSTALL_DIR/backend"
source .venv/bin/activate
nohup uvicorn app.main:app --port 8000 > "$LOG_DIR/api.log" 2>&1 &
API_PID=$!
sleep 2
curl -s http://localhost:8000/api/dashboard/overview &>/dev/null && \
    echo -e "      ${GREEN}✓ API OK (pid $API_PID)${NC}" || \
    echo -e "      ${YELLOW}⚠ API en démarrage... (pid $API_PID)${NC}"

# ── Worker Celery ──────────────────────────────────────────
echo -e "${YELLOW}[3/4] Worker Celery...${NC}"
nohup celery -A app.workers.celery_app.celery_app worker \
    --loglevel=warning > "$LOG_DIR/celery.log" 2>&1 &
CELERY_PID=$!
echo -e "      ${GREEN}✓ Worker OK (pid $CELERY_PID)${NC}"
deactivate

# ── Frontend React ─────────────────────────────────────────
echo -e "${YELLOW}[4/4] Frontend...${NC}"
cd "$INSTALL_DIR/frontend"
nohup npm run dev > "$LOG_DIR/frontend.log" 2>&1 &
FRONTEND_PID=$!
sleep 3
echo -e "      ${GREEN}✓ Frontend OK (pid $FRONTEND_PID)${NC}"

# ── Ouvrir le navigateur ───────────────────────────────────
echo ""
echo -e "${GREEN}╔══════════════════════════════════════╗${NC}"
echo -e "${GREEN}║   Postulator prêt !                  ║${NC}"
echo -e "${GREEN}║   → http://localhost:5173            ║${NC}"
echo -e "${GREEN}║                                      ║${NC}"
echo -e "${GREEN}║   Logs : ~/.postulator/logs/         ║${NC}"
echo -e "${GREEN}║   Arrêt : Ctrl+C                     ║${NC}"
echo -e "${GREEN}╚══════════════════════════════════════╝${NC}"
echo ""

# Ouvrir le navigateur
sleep 1
if command -v xdg-open &>/dev/null; then
    xdg-open http://localhost:5173 &
elif command -v gnome-open &>/dev/null; then
    gnome-open http://localhost:5173 &
fi

# Garder le script actif — arrêt propre sur Ctrl+C
trap "echo ''; echo 'Arrêt de Postulator...'; kill $API_PID $CELERY_PID $FRONTEND_PID 2>/dev/null; exit 0" INT TERM
wait
